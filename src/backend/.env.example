# ── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Algorand Network ─────────────────────────────────────
ALGORAND_NETWORK=testnet
ALGOD_URL=https://testnet-api.algonode.cloud
ALGOD_TOKEN=
# leave ALGOD_TOKEN blank — Algonode public node requires no token
INDEXER_URL=https://testnet-idx.algonode.cloud

# ── Platform Wallet (receives payments) ──────────────────
PLATFORM_WALLET_ADDRESS=YOUR_58_CHARACTER_ALGORAND_ADDRESS_HERE
PLATFORM_WALLET_MNEMONIC=word1 word2 word3 ... word25

# ── Smart Contract (set AFTER running deploy_config.py) ──
ALGORAND_APP_ID=0
# Replace 0 with the actual APP_ID printed during deployment

# ── App ──────────────────────────────────────────────────
APP_SECRET_KEY=replace-with-a-long-random-string-minimum-32-chars
SESSION_EXPIRY_SECONDS=600
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# ── Creator Encryption ───────────────────────────────────
# Generate with: python -c "import os; print(os.urandom(32).hex())"
API_KEY_ENCRYPTION_SECRET=your_32_byte_hex_encryption_secret_here
